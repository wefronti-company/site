# Banco de dados (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# JWT para sessão do admin (gere um segredo forte em produção)
JWT_SECRET=seu-segredo-jwt-forte

# Segredo para logging de eventos de segurança (middleware -> API interna)
SECURITY_LOG_SECRET=seu-segredo-interno-forte
 